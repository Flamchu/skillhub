# database (using supabase postgresql)
DATABASE_URL=postgresql://postgres.xxx:password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# redis (set to false for local dev, true for docker)
REDIS_ENABLED=false
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# object storage (minio / s3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadminpassword
S3_BUCKET=skillhub-media
S3_PUBLIC_URL=http://localhost:9000/skillhub-media
S3_FORCE_PATH_STYLE=true

# supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# local ai service (sentence-transformer)
LOCAL_AI_SERVICE_URL=http://ai-service:5000
AI_SERVICE_ENABLED=true

# udemy api integration (optional - leave empty if not using)
# get credentials at: https://www.udemy.com/developers/affiliate/
UDEMY_CLIENT_ID=
UDEMY_CLIENT_SECRET=
UDEMY_AFFILIATE_ID=

# frontend
FRONTEND_URL=https://skillhub.lopataa.site
NEXT_PUBLIC_BACKEND_URL=https://skillhub.lopataa.site/api

# backend
PORT=4000
NODE_ENV=development
