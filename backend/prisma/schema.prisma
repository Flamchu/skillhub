generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String                     @id @default(uuid())
  name                     String?
  email                    String?                    @unique
  bio                      String?
  createdAt                DateTime                   @default(now())
  headline                 String?
  regionId                 String?
  role                     Role                       @default(USER)
  updatedAt                DateTime                   @updatedAt
  supabaseId               String                     @unique
  deletedAt                DateTime?
  profilePicture           String?
  xp                       Int                        @default(0)
  level                    Int                        @default(1)
  currentStreak            Int                        @default(0)
  longestStreak            Int                        @default(0)
  lastActivityDate         DateTime?
  socialEnabled            Boolean                    @default(false)
  bookmarks                Bookmark[]
  enrollments              Enrollment[]
  recommendations          Recommendation[]
  Test                     Test[]
  testAttempts             TestAttempt[]
  region                   Region?                    @relation(fields: [regionId], references: [id])
  userProgress             UserProgress[]
  skills                   UserSkill[]
  verificationAttempts     SkillVerificationAttempt[]
  questCompletions         QuestCompletion[]
  xpTransactions           XPTransaction[]

  @@index([regionId])
  @@index([supabaseId])
  @@index([deletedAt])
  @@index([xp])
  @@index([level])
  @@index([currentStreak])
  @@index([lastActivityDate])
  @@index([socialEnabled])
}

model Skill {
  id                       String                     @id @default(uuid())
  name                     String                     @unique
  createdAt                DateTime                   @default(now())
  description              String?
  parentId                 String?
  slug                     String                     @unique
  updatedAt                DateTime                   @updatedAt
  category                 String?
  courses                  CourseSkill[]
  Recommendation           Recommendation[]
  parent                   Skill?                     @relation("SkillParent", fields: [parentId], references: [id])
  children                 Skill[]                    @relation("SkillParent")
  SkillMarketStat          SkillMarketStat[]
  tests                    Test[]
  UserSkill                UserSkill[]
  verificationQuestions    SkillVerificationQuestion[]
  verificationAttempts     SkillVerificationAttempt[]

  @@index([parentId])
  @@index([name])
  @@index([slug])
  @@index([category])
}

model UserSkill {
  id                    String            @id @default(uuid())
  userId                String
  skillId               String
  createdAt             DateTime          @default(now())
  lastPracticed         DateTime?
  proficiency           ProficiencyLevel  @default(BASIC)
  progress              Int               @default(0)
  targetLevel           ProficiencyLevel?
  updatedAt             DateTime          @updatedAt
  isVerified            Boolean           @default(false)
  verificationAttemptId String?
  skill                 Skill             @relation(fields: [skillId], references: [id])
  user                  User              @relation(fields: [userId], references: [id])

  @@unique([userId, skillId])
  @@index([skillId])
  @@index([proficiency])
  @@index([progress])
  @@index([lastPracticed])
  @@index([isVerified])
}

model Course {
  id              String           @id @default(uuid())
  title           String
  url             String?
  createdAt       DateTime         @default(now())
  description     String?
  difficulty      CourseDifficulty @default(BEGINNER)
  durationMinutes Int?
  externalId      String?
  isPaid          Boolean          @default(false)
  language        String?          @default("en")
  priceCents      Int?
  provider        String?
  rating          Float?
  updatedAt       DateTime         @updatedAt
  source          CourseSource     @default(INTERNAL)
  thumbnail       String?
  aiSummary       String?
  Bookmark        Bookmark[]
  skills          CourseSkill[]
  enrollments     Enrollment[]
  lessons         Lesson[]
  Recommendation  Recommendation[]

  @@index([provider, source])
  @@index([difficulty])
  @@index([isPaid])
  @@index([rating])
  @@index([language])
  @@index([createdAt])
  @@index([externalId])
}

model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([enrolledAt])
  @@index([isCompleted])
}

model CourseSkill {
  id        String @id @default(uuid())
  courseId  String
  skillId   String
  relevance Int    @default(50)
  course    Course @relation(fields: [courseId], references: [id])
  skill     Skill  @relation(fields: [skillId], references: [id])

  @@unique([courseId, skillId])
  @@index([skillId])
}

model Test {
  id             String            @id @default(uuid())
  title          String
  skillId        String?
  difficulty     CourseDifficulty?
  totalQuestions Int?
  published      Boolean           @default(true)
  createdById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdBy      User?             @relation(fields: [createdById], references: [id])
  skill          Skill?            @relation(fields: [skillId], references: [id])
  TestAttempt    TestAttempt[]
  questions      TestQuestion[]
}

model TestQuestion {
  id        String       @id @default(uuid())
  testId    String
  text      String
  type      QuestionType @default(MULTIPLE_CHOICE)
  order     Int          @default(0)
  points    Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  choices   TestChoice[]
  test      Test         @relation(fields: [testId], references: [id])
}

model TestChoice {
  id         String       @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean      @default(false)
  order      Int          @default(0)
  question   TestQuestion @relation(fields: [questionId], references: [id])
}

model TestAttempt {
  id          String    @id @default(uuid())
  userId      String
  testId      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  score       Float?
  answers     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  test        Test      @relation(fields: [testId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([testId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Recommendation {
  id        String                  @id @default(uuid())
  userId    String
  skillId   String?
  courseId  String?
  algorithm RecommendationAlgorithm @default(RULES)
  score     Float                   @default(0)
  meta      Json?
  createdAt DateTime                @default(now())
  course    Course?                 @relation(fields: [courseId], references: [id])
  skill     Skill?                  @relation(fields: [skillId], references: [id])
  user      User                    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Region {
  id         String            @id @default(uuid())
  name       String            @unique
  code       String?
  createdAt  DateTime          @default(now())
  skillStats SkillMarketStat[]
  users      User[]
}

model SkillMarketStat {
  id             String   @id @default(uuid())
  skillId        String
  regionId       String
  usersCount     Int      @default(0)
  avgProficiency Float?
  demandScore    Float?
  updatedAt      DateTime @updatedAt
  region         Region   @relation(fields: [regionId], references: [id])
  skill          Skill    @relation(fields: [skillId], references: [id])

  @@unique([skillId, regionId])
}

model Lesson {
  id              String         @id @default(uuid())
  courseId        String
  title           String
  description     String?
  position        Int
  providerVideoId String?
  url             String?
  durationSeconds Int?
  thumbnail       String?
  isCompleted     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userProgress    UserProgress[]

  @@index([courseId])
  @@index([position])
  @@index([providerVideoId])
}

model UserProgress {
  id               String    @id @default(uuid())
  userId           String
  lessonId         String
  completed        Boolean   @default(false)
  progressPercent  Int?      @default(0)
  watchTimeSeconds Int?      @default(0)
  lastAccessedAt   DateTime  @default(now())
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lesson           Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([completed])
  @@index([lastAccessedAt])
}

model SkillVerificationQuestion {
  id                    String                           @id @default(uuid())
  skillId               String
  questionText          String
  difficultyLevel       ProficiencyLevel                 @default(INTERMEDIATE)
  points                Int                              @default(1)
  order                 Int                              @default(0)
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  skill                 Skill                            @relation(fields: [skillId], references: [id], onDelete: Cascade)
  choices               SkillVerificationChoice[]
  userAnswers           SkillVerificationUserAnswer[]

  @@index([skillId])
  @@index([difficultyLevel])
  @@index([order])
}

model SkillVerificationChoice {
  id          String                    @id @default(uuid())
  questionId  String
  choiceText  String
  label       String
  isCorrect   Boolean                   @default(false)
  order       Int                       @default(0)
  question    SkillVerificationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([order])
}

model SkillVerificationAttempt {
  id                 String                        @id @default(uuid())
  userId             String
  skillId            String
  startedAt          DateTime                      @default(now())
  completedAt        DateTime?
  totalPoints        Int                           @default(0)
  earnedPoints       Int                           @default(0)
  achievedLevel      ProficiencyLevel?
  passedVerification Boolean                       @default(false)
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  user               User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill              Skill                         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userAnswers        SkillVerificationUserAnswer[]

  @@index([userId])
  @@index([skillId])
  @@index([completedAt])
  @@index([achievedLevel])
}

model SkillVerificationUserAnswer {
  id               String                     @id @default(uuid())
  attemptId        String
  questionId       String
  selectedChoices  String[]
  isCorrect        Boolean                    @default(false)
  pointsEarned     Int                        @default(0)
  createdAt        DateTime                   @default(now())
  attempt          SkillVerificationAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         SkillVerificationQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
}

enum Role {
  USER
  INSTRUCTOR
  ADMIN
}

enum ProficiencyLevel {
  NONE
  BASIC
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CourseSource {
  INTERNAL
  YOUTUBE
  UDEMY
  OTHER
}

enum CourseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MULTIPLE_CHOICE
  OPEN
}

enum RecommendationAlgorithm {
  RULES
  CONTENT_BASED
  COLLAB_FILTER
  HYBRID
  SEMANTIC
}

model Quest {
  id               String            @id @default(uuid())
  title            String
  description      String
  type             QuestType
  xpReward         Int               @default(50)
  targetCount      Int               @default(1)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  completions      QuestCompletion[]

  @@index([type])
  @@index([isActive])
}

model QuestCompletion {
  id               String    @id @default(uuid())
  userId           String
  questId          String
  completedAt      DateTime  @default(now())
  progress         Int       @default(0)
  isCompleted      Boolean   @default(false)
  xpAwarded        Int       @default(0)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest            Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, completedAt])
  @@index([userId])
  @@index([questId])
  @@index([completedAt])
  @@index([isCompleted])
}

model XPTransaction {
  id          String            @id @default(uuid())
  userId      String
  amount      Int
  source      XPSource
  description String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
  @@index([createdAt])
}

enum QuestType {
  DAILY_LOGIN
  COMPLETE_LESSON
  COMPLETE_COURSE
  ADD_SKILL
  VERIFY_SKILL
  BOOKMARK_COURSE
  COMPLETE_TEST
  STUDY_TIME
  COMPLETE_MULTIPLE_LESSONS
  PERFECT_SCORE
}

enum XPSource {
  QUEST_COMPLETION
  LESSON_COMPLETION
  COURSE_COMPLETION
  SKILL_VERIFICATION
  DAILY_LOGIN
  STREAK_BONUS
  ACHIEVEMENT
  ADMIN_GRANT
}
