datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// enums
enum Role {
  USER
  INSTRUCTOR
  ADMIN
}

enum ProficiencyLevel {
  NONE
  BASIC
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CourseSource {
  INTERNAL
  YOUTUBE
  UDEMY
  OTHER
}

enum CourseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MULTIPLE_CHOICE
  OPEN
}

enum RecommendationAlgorithm {
  RULES
  CONTENT_BASED
  COLLAB_FILTER
  HYBRID
}

// models
model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique // links to supabase auth user
  email      String?  @unique // optional since supabase handles email verification
  name       String?
  headline   String?
  bio        String?
  regionId   String?
  region     Region?  @relation(fields: [regionId], references: [id])
  role       Role     @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  skills          UserSkill[]
  testAttempts    TestAttempt[]
  bookmarks       Bookmark[]
  recommendations Recommendation[]
  Test            Test[]

  @@index([regionId])
  @@index([supabaseId])
}

model Skill {
  id              String            @id @default(uuid())
  name            String            @unique
  slug            String            @unique
  description     String?
  parentId        String?
  parent          Skill?            @relation("SkillParent", fields: [parentId], references: [id])
  children        Skill[]           @relation("SkillParent")
  courses         CourseSkill[]
  tests           Test[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  UserSkill       UserSkill[]
  Recommendation  Recommendation[]
  SkillMarketStat SkillMarketStat[]

  @@index([parentId])
  @@index([name])
  @@index([slug])
}

model UserSkill {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  skillId       String
  skill         Skill             @relation(fields: [skillId], references: [id])
  proficiency   ProficiencyLevel  @default(BASIC)
  targetLevel   ProficiencyLevel?
  progress      Int               @default(0) // 0-100 completion
  lastPracticed DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, skillId])
  @@index([skillId])
  @@index([proficiency])
  @@index([progress])
  @@index([lastPracticed])
}

model Course {
  id              String           @id @default(uuid())
  title           String
  description     String?
  provider        String? // e.g. "udemy", "youtube channel", "internal"
  source          CourseSource     @default(INTERNAL)
  externalId      String? // provider-specific id (youtube video id, udemy course id)
  url             String?
  language        String?          @default("en")
  difficulty      CourseDifficulty @default(BEGINNER)
  durationMinutes Int?
  rating          Float?
  isPaid          Boolean          @default(false)
  priceCents      Int? // prices stored as cents
  tags            CourseTag[]
  skills          CourseSkill[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  Bookmark        Bookmark[]
  Recommendation  Recommendation[]

  @@index([provider, source])
  @@index([difficulty])
  @@index([isPaid])
  @@index([rating])
  @@index([language])
  @@index([createdAt])
}

model CourseSkill {
  id        String @id @default(uuid())
  course    Course @relation(fields: [courseId], references: [id])
  courseId  String
  skill     Skill  @relation(fields: [skillId], references: [id])
  skillId   String
  relevance Int    @default(50) // 0-100 relevance

  @@unique([courseId, skillId])
  @@index([skillId])
}

model Tag {
  id      String      @id @default(uuid())
  name    String      @unique
  courses CourseTag[]
}

model CourseTag {
  id       String @id @default(uuid())
  course   Course @relation(fields: [courseId], references: [id])
  courseId String
  tag      Tag    @relation(fields: [tagId], references: [id])
  tagId    String

  @@unique([courseId, tagId])
}

model Test {
  id             String            @id @default(uuid())
  title          String
  skillId        String?
  skill          Skill?            @relation(fields: [skillId], references: [id])
  difficulty     CourseDifficulty?
  totalQuestions Int?
  published      Boolean           @default(true)
  questions      TestQuestion[]
  createdById    String?
  createdBy      User?             @relation(fields: [createdById], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  TestAttempt    TestAttempt[]
}

model TestQuestion {
  id        String       @id @default(uuid())
  testId    String
  test      Test         @relation(fields: [testId], references: [id])
  text      String
  type      QuestionType @default(MULTIPLE_CHOICE)
  order     Int          @default(0)
  points    Int          @default(1)
  choices   TestChoice[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model TestChoice {
  id         String       @id @default(uuid())
  questionId String
  question   TestQuestion @relation(fields: [questionId], references: [id])
  text       String
  isCorrect  Boolean      @default(false)
  order      Int          @default(0)
}

model TestAttempt {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  testId      String
  test        Test      @relation(fields: [testId], references: [id])
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  score       Float?
  answers     Json? // structured answers for analytics
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([testId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Recommendation {
  id        String                  @id @default(uuid())
  userId    String
  user      User                    @relation(fields: [userId], references: [id])
  skillId   String?
  skill     Skill?                  @relation(fields: [skillId], references: [id])
  courseId  String?
  course    Course?                 @relation(fields: [courseId], references: [id])
  algorithm RecommendationAlgorithm @default(RULES)
  score     Float                   @default(0)
  meta      Json? // explanation, rationale, features
  createdAt DateTime                @default(now())

  @@index([userId])
}

model Region {
  id         String            @id @default(uuid())
  name       String
  code       String?
  users      User[]
  skillStats SkillMarketStat[]
  createdAt  DateTime          @default(now())

  @@unique([name])
}

model SkillMarketStat {
  id             String   @id @default(uuid())
  skillId        String
  skill          Skill    @relation(fields: [skillId], references: [id])
  regionId       String
  region         Region   @relation(fields: [regionId], references: [id])
  usersCount     Int      @default(0)
  avgProficiency Float?
  demandScore    Float?
  updatedAt      DateTime @updatedAt

  @@unique([skillId, regionId])
}
